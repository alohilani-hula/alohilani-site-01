---
const { buttonUrl, buttonText, buttonAriaLabel, buttonTarget } = Astro.props;
---


<a href={buttonUrl} target={buttonTarget} rel={buttonTarget === "_blank" ? "noopener noreferrer" : undefined} aria-label={buttonAriaLabel} class="c-button">{buttonText}</a>

<style is:global lang="scss">
  @use '../../styles/breakpoints' as *;

  .c-button {
    display: inline-block;
    padding-block: 9px;
    padding-inline: 16px calc(16px + 16px + 8px);
    border-radius: 100px;
    background-color: var(--color-main);
    color: var(--color-white);
    line-height: 1.5;
    position: relative;

    &::before,
    &::after {
      content: "";
      margin-block: auto;
      position: absolute;
      top: 0;
      bottom: 0;
    }

    &::before {
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background-color: var(--color-white);
      right: 16px;
    }

    &::after {
      width: 5px;
      height: 9px;
      background-image: url(/assets/images/global/icon-arrow.svg);
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
      right: calc(16px + 5px);
    }
  }

  @include mq() {
    .c-button {
      padding-block: 16px;
      padding-inline: 24px calc(24px + 20px + 16px);

      &::before {
        width: 22px;
        height: 22px;
        right: 24px;
      }

      &::after {
        width: 7px;
        height: 12px;
        right: calc(24px + 7px);
      }
    }
  }

  @media (any-hover: hover) {
    .c-button {
      transition: filter .5s ease;

      &:hover {
        filter: brightness(85%) contrast(115%);
      }
    }
  }
</style>
