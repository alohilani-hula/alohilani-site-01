<form class="c-form" action="https://ssgform.com/s/IwInHqz40lca" method="post" novalidate>
  <div class="c-form-honeypot" aria-hidden="true">
    <label for="wana">Leave this field empty</label>
    <input id="wana" type="text" name="wana" tabindex="-1" autocomplete="off" />
  </div>

  <div class="c-form-field">
    <label for="name" class="c-form-label">
      お名前 <span class="c-form-required" aria-label="必須">必須</span>
    </label>
    <input type="text" id="name" name="name" autocomplete="name" placeholder="例）山田 花子" class="c-form-input" required aria-describedby="name-error" />
    <p id="name-error" class="c-form-error" aria-live="polite"></p>
  </div>

  <div class="c-form-field">
    <label for="ruby" class="c-form-label">
      ふりがな <span class="c-form-required" aria-label="必須">必須</span>
    </label>
    <input type="text" id="ruby" name="ruby" placeholder="例）やまだ はなこ" class="c-form-input" required aria-describedby="ruby-error" />
    <p id="ruby-error" class="c-form-error" aria-live="polite"></p>
  </div>

  <div class="c-form-field">
    <label for="email" class="c-form-label">
      メールアドレス <span class="c-form-required" aria-label="必須">必須</span>
    </label>
    <input type="email" id="email" name="email" autocomplete="email" placeholder="例）info@example.com" class="c-form-input" required inputmode="email" aria-describedby="email-error" />
    <p id="email-error" class="c-form-error" aria-live="polite"></p>
  </div>

  <div class="c-form-field">
    <label for="tel" class="c-form-label">
      電話番号 <span class="c-form-required" aria-label="必須">必須</span>
    </label>
    <input type="tel" id="tel" name="tel" autocomplete="tel" placeholder="例）090-1234-5678" class="c-form-input" required inputmode="tel" aria-describedby="tel-error" />
    <p id="tel-error" class="c-form-error" aria-live="polite"></p>
  </div>

  <fieldset class="c-form-field c-form-group" data-required-group="age">
    <legend class="c-form-label">
      年齢区分 <span class="c-form-required" aria-label="必須">必須</span>
    </legend>
    <p class="c-form-help">体験をご希望の方の年齢区分をお選びください。<br>複数名で参加される場合は、該当するものをすべて選択してください。</p>

    <div class="c-form-options">
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="未就学児" /> <span class="c-form-checkbox-text">未就学児</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="小学生" /> <span class="c-form-checkbox-text">小学生</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="中学生" /> <span class="c-form-checkbox-text">中学生</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="高校生" /> <span class="c-form-checkbox-text">高校生</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="10代" /> <span class="c-form-checkbox-text">10代</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="20～30代" /> <span class="c-form-checkbox-text">20～30代</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="40～50代" /> <span class="c-form-checkbox-text">40～50代</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="age[]" value="60代以上" /> <span class="c-form-checkbox-text">60代以上</span></label>
    </div>
    <p id="age-error" class="c-form-error" aria-live="polite"></p>
  </fieldset>

  <fieldset class="c-form-field c-form-group">
    <legend class="c-form-label">
      フラの経験 <span class="c-form-required" aria-label="必須">必須</span>
    </legend>
    <div class="c-form-options">
      <label class="c-form-radio-label"><input type="radio" name="experience" value="無し" required checked/> <span>無し</span></label>
      <label class="c-form-radio-label"><input type="radio" name="experience" value="有り" /> <span>有り</span></label>
    </div>
    <p id="experience-error" class="c-form-error" aria-live="polite"></p>
  </fieldset>

  <fieldset class="c-form-field c-form-group" data-required-group="class">
    <legend class="c-form-label">
      参加希望クラス <span class="c-form-required" aria-label="必須">必須</span>
    </legend>

    <div class="c-form-class-group">
      <p class="c-form-group-title">江古田教室</p>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="江古田教室 ケイキ初級クラス（子供対象）" /> <span class="c-form-checkbox-text">ケイキ初級クラス（子供対象）</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="江古田教室 ケイキ中級クラス（子供対象）" /> <span class="c-form-checkbox-text">ケイキ中級クラス（子供対象）</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="江古田教室 ワヒネ・クプナクラス（大人対象）" /> <span class="c-form-checkbox-text">ワヒネ・クプナクラス（大人対象）</span></label>
    </div>

    <div class="c-form-class-group">
      <p class="c-form-group-title">練馬教室</p>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="練馬教室 親子フラクラス（親子対象）" /> <span class="c-form-checkbox-text">親子フラクラス（親子対象）</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="練馬教室 ワヒネ・クプナクラス（大人対象）" /> <span class="c-form-checkbox-text">ワヒネ・クプナクラス（大人対象）</span></label>
    </div>

    <div class="c-form-class-group">
      <p class="c-form-group-title">中野教室</p>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="中野教室 ケイキ初級クラス（子供対象）" /> <span class="c-form-checkbox-text">ケイキ初級クラス（子供対象）</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="中野教室 ケイキ中級クラス（子供対象）" /> <span class="c-form-checkbox-text">ケイキ中級クラス（子供対象）</span></label>
    </div>

    <div class="c-form-class-group">
      <p class="c-form-group-title">その他</p>
      <label class="c-form-checkbox-label"><input type="checkbox" name="class[]" value="その他のレッスン" /> <span class="c-form-checkbox-text">その他のレッスン</span></label>
    </div>

    <p id="class-error" class="c-form-error" aria-live="polite"></p>
  </fieldset>

  <fieldset class="c-form-field c-form-group" data-required-group="source">
    <legend class="c-form-label">
      当教室をどこで知りましたか？ <span class="c-form-required" aria-label="必須">必須</span>
    </legend>
    <div class="c-form-options">
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="ホームページ" /> <span class="c-form-checkbox-text">ホームページ</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="SNS（Instagramなど）" /> <span class="c-form-checkbox-text">SNS（Instagramなど）</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="知り合いの紹介" /> <span class="c-form-checkbox-text">知り合いの紹介</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="チラシ" /> <span class="c-form-checkbox-text">チラシ</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="イベント参加" /> <span class="c-form-checkbox-text">イベント参加</span></label>
      <label class="c-form-checkbox-label"><input type="checkbox" name="source[]" value="その他" /> <span class="c-form-checkbox-text">その他</span></label>
    </div>
    <p id="source-error" class="c-form-error" aria-live="polite"></p>
  </fieldset>

  <div class="c-form-field">
    <label for="message" class="c-form-label">
      体調面で不安なことや、事前に聞きたいことがありましたら、ご記入ください。
    </label>
    <textarea id="message" name="message" rows="6" placeholder="ご質問や不安なことがありましたら、お気軽にご記入ください。" class="c-form-textarea" aria-describedby="message-error"></textarea>
    <p id="message-error" class="c-form-error" aria-live="polite"></p>
  </div>

  <div class="c-form-privacy-policy">
    <p id="privacy-description" class="c-form-privacy-policy-text">
      <a href="/privacy-policy" target="_blank" rel="noopener noreferrer">
        プライバシーポリシー<span class="u-visually-hidden">（新しいタブで開きます）</span>
      </a>に同意の上、チェックしてください。
    </p>
    <div class="c-form-field c-form-privacy-checkbox">
      <label class="c-form-label c-form-privacy-checkbox-label" for="privacy">
        <input id="privacy" name="privacy" type="checkbox" required aria-describedby="privacy-description privacy-error" />
        <span class="c-form-privacy-checkbox-text">プライバシーポリシーに同意する。</span>
      </label>
    </div>
    <p id="privacy-error" class="c-form-error c-form-error--privacy" aria-live="polite"></p>
  </div>

  <div class="c-form-submit">
    <button type="submit" class="c-form-submit-btn">体験レッスンを予約する</button>
  </div>
</form>

<script>
  (() => {
    const form = document.querySelector('.c-form');
    if (!form) return;

    const hp = form.querySelector('input[name="wana"]');

    const fields = {
      name: {
        input: form.querySelector('#name'),
        error: form.querySelector('#name-error'),
        messages: { valueMissing: 'お名前を入力してください。' },
      },
      ruby: {
        input: form.querySelector('#ruby'),
        error: form.querySelector('#ruby-error'),
        messages: { valueMissing: 'ふりがなを入力してください。' },
      },
      email: {
        input: form.querySelector('#email'),
        error: form.querySelector('#email-error'),
        messages: {
          valueMissing: 'メールアドレスを入力してください。',
          typeMismatch: 'メールアドレスの形式が正しくありません。',
        },
      },
      tel: {
        input: form.querySelector('#tel'),
        error: form.querySelector('#tel-error'),
        messages: { valueMissing: '電話番号を入力してください。' },
      },
      experience: {
        inputs: [...form.querySelectorAll('input[name="experience"]')],
        error: form.querySelector('#experience-error'),
        message: 'フラの経験を選択してください。',
      },
      privacy: {
        input: form.querySelector('#privacy'),
        error: form.querySelector('#privacy-error'),
        messages: { valueMissing: 'プライバシーポリシーに同意してください。' },
      },
    };

    const checkboxGroups = {
      age: {
        root: form.querySelector('[data-required-group="age"]'),
        inputs: [...form.querySelectorAll('input[name="age[]"]')],
        error: form.querySelector('#age-error'),
        message: '年齢区分を1つ以上選択してください。',
      },
      class: {
        root: form.querySelector('[data-required-group="class"]'),
        inputs: [...form.querySelectorAll('input[name="class[]"]')],
        error: form.querySelector('#class-error'),
        message: '参加希望クラスを1つ以上選択してください。',
      },
      source: {
        root: form.querySelector('[data-required-group="source"]'),
        inputs: [...form.querySelectorAll('input[name="source[]"]')],
        error: form.querySelector('#source-error'),
        message: '当教室をどこで知ったかを1つ以上選択してください。',
      },
    };

    const setError = (input, error, message = '') => {
      if (error) error.textContent = message;
      if (input) input.setAttribute('aria-invalid', message ? 'true' : 'false');
    };

    const setGroupError = (group, message = '') => {
      if (group.error) group.error.textContent = message;
      group.inputs.forEach((input) => {
        input.setAttribute('aria-invalid', message ? 'true' : 'false');
      });
    };

    const getMessage = (input, messages) => {
      const { validity } = input;
      if (validity.valid) return '';
      if (validity.valueMissing) return messages.valueMissing;
      if (validity.typeMismatch) return messages.typeMismatch;
      return '入力内容を確認してください。';
    };

    const validateField = (key) => {
      const { input, error, messages } = fields[key];
      const message = getMessage(input, messages);
      setError(input, error, message);
      return !message;
    };

    const validateRadioGroup = (key) => {
      const group = fields[key];
      const isChecked = group.inputs.some((input) => input.checked);
      const message = isChecked ? '' : group.message;

      group.inputs.forEach((input) => {
        input.setAttribute('aria-invalid', message ? 'true' : 'false');
      });
      if (group.error) group.error.textContent = message;

      return isChecked;
    };

    const validateCheckboxGroup = (key) => {
      const group = checkboxGroups[key];
      const isChecked = group.inputs.some((input) => input.checked);
      const message = isChecked ? '' : group.message;

      setGroupError(group, message);
      return isChecked;
    };

    const validatePrivacy = () => {
      const { input, error, messages } = fields.privacy;
      const message = input.checked ? '' : messages.valueMissing;
      setError(input, error, message);
      return !message;
    };

    const validateAll = () => {
      if (hp && hp.value.trim() !== '') return false;

      return [
        validateField('name'),
        validateField('ruby'),
        validateField('email'),
        validateField('tel'),
        validateCheckboxGroup('age'),
        validateRadioGroup('experience'),
        validateCheckboxGroup('class'),
        validateCheckboxGroup('source'),
        validatePrivacy(),
      ].every(Boolean);
    };

    ['name', 'ruby', 'email', 'tel'].forEach((key) => {
      fields[key].input.addEventListener('blur', () => validateField(key));
    });

    fields.experience.inputs.forEach((input) => {
      input.addEventListener('change', () => validateRadioGroup('experience'));
    });

    Object.keys(checkboxGroups).forEach((key) => {
      checkboxGroups[key].inputs.forEach((input) => {
        input.addEventListener('change', () => validateCheckboxGroup(key));
      });
    });

    fields.privacy.input.addEventListener('change', validatePrivacy);

    form.addEventListener('submit', (e) => {
      if (validateAll()) return;

      e.preventDefault();

      const firstInvalid =
        form.querySelector('[aria-invalid="true"]') ||
        form.querySelector(':invalid');

      firstInvalid?.focus?.();
    });
  })();
</script>

<style lang="scss">
  @use '../../styles/_breakpoints.scss' as *;

  .c-form {
    display: grid;
    gap: 8px;
    position: relative;
  }

  .c-form-group {
    border: none;
    padding: 0;
    margin-inline: 0;
  }

  .c-form-help {
    margin-block: 8px;
    font-size: 14px;
    line-height: 1.7;
  }

  .c-form-group-title {
    margin-block-start: 16px;
    font-weight: 700;
  }

  .c-form-label {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    line-height: 1.7;
  }

  .c-form-required {
    padding-block: 5px;
    padding-inline: 12px;
    background-color: #cd3939;
    color: var(--color-white);
    font-size: 12px;
    line-height: 1;
  }

  .c-form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  input[type='text'],
  input[type='email'],
  input[type='tel'],
  textarea {
    width: 100%;
    padding-block: 8px;
    padding-inline: 16px;
    margin-top: 8px;
    border: none;
    box-shadow: 0 0 0 1px #999 inset;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-color: #fff;

    &:focus {
      outline: 0;
      box-shadow: 0 0 0 2px rgb(33 150 243) inset;
    }

    &::placeholder {
      color: #999;
      font-size: 15px;
    }

    &[aria-invalid='true'] {
      box-shadow: 0 0 0 2px #cd3939 inset;
    }
  }

  textarea {
    height: 220px;
    resize: vertical;
    overflow: auto;
  }

  // チェックボックス、ラジオボタン
  .c-form-checkbox-label,
  .c-form-radio-label {
    display: block;
  }

  // エラーメッセージ
  .c-form-error {
    margin-block: 4px;
    font-size: 14px;
    line-height: 1.6;
    color: #cd3939;
    min-height: 24px; // 文字がない時のガタつき防止
    text-align: justify;

    &--privacy {
      width: fit-content;
      margin-inline: auto;
    }
  }

  // プライバシーポリシー
  .c-form-privacy-policy {
    margin-block-start: 16px;
  }

  .c-form-privacy-policy-text {
    gap: 8px;
    width: fit-content;
    margin-inline: auto;
    line-height: 2;

    a {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      margin-inline-end: 8px;
      position: relative;

      &::before {
        content: "";
        width: 100%;
        height: 1px;
        background-color: currentColor;
        position: absolute;
        bottom: 4px;
        left: 0;
      }

      &::after {
        content: "";
        width: 16px;
        height: 14px;
        background-image: url(/assets/images/global/icon-external-link.svg);
        background-repeat: no-repeat;
        background-size: contain;
        background-position: center center;
      }
    }
  }

  .c-form-privacy-checkbox {
    position: relative;
    margin-block-start: 32px;
  }

  .c-form-privacy-checkbox-label {
    display: flex;
    gap: 8px;
    width: fit-content;
    margin-inline: auto;
    font-weight: 400;
    cursor: pointer;
  }

  .c-form-privacy-checkbox input {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }

  .c-form-privacy-checkbox-text {
    position: relative;
    display: flex;
    gap: 8px;
    cursor: pointer;

    &::before {
      content: '';
      width: 18px;
      height: 18px;
      border-radius: 3px;
      border: 1px solid #999;
      flex-shrink: 0;
      background-color: #fff;
      margin-block-start: 4px;
    }
  }

  .c-form-privacy-checkbox input:checked + .c-form-privacy-checkbox-text::after {
    content: '';
    position: absolute;
    top: 4px;
    left: 0.315em;
    transform: rotate(45deg);
    width: 0.5em;
    height: 0.8em;
    border: solid var(--color-main);
    border-width: 0 2px 2px 0;
  }

  .c-form-privacy-checkbox input[aria-invalid='true'] + .c-form-privacy-checkbox-text::before {
    border-color: #cd3939;
  }

  .c-form-privacy-checkbox input:focus-visible + .c-form-privacy-checkbox-text {
    background: linear-gradient(transparent 90%, rgba(33, 150, 243, 0.3) 90%);
  }

  // 送信ボタン
  .c-form-submit {
    margin-block-start: 24px;
    text-align: center;
  }

  .c-form-submit-btn {
    display: inline-flex;
    gap: 24px;
    align-items: center;
    padding-block: 16px;
    padding-inline: 40px;
    border-radius: 100px;
    background-color: var(--color-main);
    color: var(--color-white);
    font-weight: 700;
    letter-spacing: .05em;
    line-height: 1.5;
    border: none;
    cursor: pointer;

    @media (any-hover: hover) {
      transition: filter .5s ease;

      &:hover {
        filter: brightness(80%) contrast(120%);
      }
    }
  }
</style>
