---
import TopTitleLv2 from "./TopTitleLv2.astro"
import Button from "../common/Button.astro"
---

<section class="top-lesson">
  <div class="l-container">
    <div class="l-section">
      <div class="top-lesson-title-lv2">
        <TopTitleLv2
          title="クラス紹介"
          titleClass="c-top-title-lv2 c-top-title-lv2--white"
          titleImagePath="/assets/images/text/text-section-title-lesson.svg"
          titleImageWidth="165"
          titleImageHeight="46"
        />
      </div>
      <div class="l-section-body">
        <ul class="top-lesson-list">
          <li class="top-lesson-item">
            <h3 class="top-lesson-title-lv3">親子フラ</h3>
            <div class="top-lesson-image">
              <img src="/assets/images/top/pic-top-lesson-01.webp" alt="" loading="lazy" decoding="async" width="680" height="450">
            </div>
          </li>
          <li class="top-lesson-item">
            <h3 class="top-lesson-title-lv3">ケイキクラス</h3>
            <div class="top-lesson-image">
              <img src="/assets/images/top/pic-top-lesson-02.webp" alt="" loading="lazy" decoding="async" width="680" height="450
              ">
            </div>
          </li>
          <li class="top-lesson-item">
            <h3 class="top-lesson-title-lv3">ワヒネ・クプナクラス</h3>
            <div class="top-lesson-image">
              <img src="/assets/images/top/pic-top-lesson-03.webp" alt="" loading="lazy" decoding="async" width="680" height="450
              ">
            </div>
          </li>
        </ul>
        <div class="top-lesson-btn">
          <Button
          buttonText="クラス紹介の詳細を見る"
          buttonUrl="/lesson"
        />
        </div>
      </div><!-- /.l-section-body -->
    </div><!-- /.l-section -->
  </div><!-- /.l-container -->
</section>

<style lang="scss">
  @use '../../styles/breakpoints' as *;

  .top-lesson {
    background-image: url(/assets/images/top/bg-top-lesson.webp);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center center;
  }

  .top-lesson-list {
    display: grid;
    gap: 48px;
    padding: 0;
  }

  .top-lesson-title-lv3 {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    color: var(--color-main);
    font-size: 20px;
    font-weight: 700;
    line-height: 1.5;

    &::before,
    &::after {
      content: "";
      width: 20px;
      height: 24px;
      background-repeat: no-repeat;
      background-size: contain;
      background-position: center center;
    }

    &::before {
      background-image: url(/assets/images/top/deco-top-lesson-left.svg);
    }

    &::after {
      background-image: url(/assets/images/top/deco-top-lesson-right.svg);
    }
  }

  .top-lesson-image {
    margin-block-start: 12px;

    img {
      max-width: 480px;
      margin-inline: auto;
    }
  }

  .top-lesson-btn {
    margin-block-start: 64px;
    text-align: center;
  }

  @include mq() {
    .top-lesson-list {
      grid-template-columns: repeat(3, 1fr);
      gap: min(48px, calc(48 / 1280 * 100vw));
    }

    .top-lesson-title-lv3 {
      gap: min(10px, calc(10 / 1280 * 100vw));
      font-size: min(24px, calc(24 / 1280 * 100vw));

      &::before,
      &::after {
        content: "";
        width: min(22px, calc(22 / 1280 * 100vw));
        height: min(24px, calc(24 / 1280 * 100vw));
      }
    }

    .top-lesson-btn {
      margin-block-start: 80px;
    }
  }
</style>
