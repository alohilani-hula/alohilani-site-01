---
import Layout from "../layouts/Layout.astro";
import PageKv from "../components/common/PageKv.astro";
import Breadcrumb from "../components/common/Breadcrumb.astro";
// import Cta from "../components/common/Cta.astro";
---

<Layout
  title="プライバシーポリシー｜Ka Pā Hula O Alohilani"
  ogType="website"
  description="Ka Pā Hula O Alohilani（アロヒラニ）のプライバシーポリシーです。個人情報の取り扱いについてご説明しています。"
  noIndex="true"
>
  <main class="privacy">
    <div class="privacy-kv">
      <PageKv
      pageTitle="プライバシーポリシー"
      pageTitleImagePath="/assets/images/text/text-page-title-privacy-policy.svg"
      pageTitleImageWidth="294"
      pageTitleImageHeight="46"
    />
    </div>
    <div class="privacy-content">
      <div class="privacy-container l-container-s">
        <p class="privacy-lead">Ka Pā Hula O Alohilani（以下「当教室」といいます。）は、本ウェブサイト上で提供するサービス（以下「本サービス」といいます。）における、ユーザーの個人情報の取扱いについて、以下のとおりプライバシーポリシーを定めます。</p>
        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第1条（個人情報）</h2>
          <p class="privacy-text">本ポリシーにおける「個人情報」とは、氏名、電話番号、メールアドレス等、特定の個人を識別できる情報をいいます。</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第2条（個人情報の収集方法）</h2>
          <p class="privacy-text">当教室は、以下の場合に個人情報を取得することがあります。</p>
          <ul class="privacy-unordered-list">
            <li class="privacy-unordered-list-item">お問い合わせフォームの送信時</li>
            <li class="privacy-unordered-list-item">体験レッスンのお申し込み時</li>
          </ul>
          <p class="privacy-text">取得する情報は、氏名、メールアドレス、電話番号等、必要な範囲に限ります。</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第3条（個人情報の利用目的）</h2>
          <p class="privacy-text">当教室は、取得した個人情報を以下の目的で利用します。</p>
          <ol class="privacy-ordered-list">
            <li class="privacy-ordered-list-item">お問い合わせへの対応</li>
            <li class="privacy-ordered-list-item">体験レッスンの受付および連絡</li>
            <li class="privacy-ordered-list-item">必要に応じたご連絡</li>
            <li class="privacy-ordered-list-item">サービス向上のための参考</li>
          </ol>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第4条（個人情報の第三者提供）</h2>
          <p class="privacy-text">当教室は、以下の場合を除き、取得した個人情報を第三者に開示または提供することはありません。</p>
          <ul class="privacy-unordered-list">
            <li class="privacy-unordered-list-item">本人の同意がある場合</li>
            <li class="privacy-unordered-list-item">法令に基づき開示が求められた場合</li>
            <li class="privacy-unordered-list-item">人の生命、身体または財産の保護のために必要であり、本人の同意を得ることが困難な場合</li>
          </ul>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第5条（アクセス解析ツールの利用）</h2>
          <p class="privacy-text">本サイトでは、サイトの利用状況を把握し、改善に役立てるために Google Analytics 4（GA4）を利用しています。<br>Google Analytics 4は、Cookie等の仕組みを利用して、利用者のアクセス情報を収集します。これらの情報は、個人を特定するものではありません。収集された情報は、Google社のプライバシーポリシーに基づいて管理されます。</p>
          <p class="privacy-text">Google Analytics 4のデータ収集・処理の仕組みについては、以下をご確認ください。</p>
          <a href="https://policies.google.com/privacy" target="_blank" class="privacy-link">https://policies.google.com/privacy</a>
          <p class="privacy-text">なお、ブラウザの設定により、Cookieの使用を無効にすることも可能です。</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第6条（個人情報の管理）</h2>
          <p class="privacy-text">当教室は、個人情報の漏えい、紛失、改ざん等を防止するため、適切な管理を行います。</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第7条（個人情報の開示・訂正・削除）</h2>
          <p class="privacy-text">本人から、自己の個人情報について開示・訂正・削除等の請求があった場合、本人確認を行ったうえで、適切に対応いたします</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第8条（プライバシーポリシーの変更）</h2>
          <p class="privacy-text">当法人は、法令の変更や運営内容の見直し等に応じて、本プライバシーポリシーの内容を適宜見直し、改善することがあります。<br>変更後のプライバシーポリシーは、本サイトに掲載した時点で効力を生じるものとします。</p>
        </section>

        <section class="privacy-section">
          <h2 class="privacy-title-lv2">第9条（お問い合わせ窓口）</h2>
          <p class="privacy-text">本ポリシーに関するお問い合わせは、以下よりご連絡ください。</p>
          <p class="privacy-text">事業者名：Ka Pā Hula O Alohilani</p>
          <p class="privacy-text">運営責任者：高橋 正子</p>
          <p class="privacy-text">お問い合わせフォーム<br>https://alohilani-hula.com/contact/</p>
        </section>

        <div class="privacy-effective-date">
          <dl class="privacy-effective-date-list">
            <dt>制定日</dt>
            <dd>2026年6月1日</dd>
          </dl>
          <p class="privacy-signature">Ka Pā Hula O Alohilani</p>
        </div><!-- /.privacy-effective-date -->
      </div><!-- /.l-container-s -->
    </div><!-- /.privacy-content -->

    <!-- breadcrumb -->
    <Breadcrumb
      siteUrl="https://alohilani-hula.com"
      breadcrumbLists={[{ name: "プライバシーポリシー", schemaName: "プライバシーポリシー" }]}
    />
  </main>

  <!-- cta -->
  <!-- <Cta /> -->
</Layout>

<style lang="scss">
  @use '../styles/breakpoints' as *;

  .privacy-content {
    padding-block-end: 80px;
    margin-block-start: 56px;
    text-align: justify;
  }

  .privacy-section {
    margin-block-start: 32px;
  }

  .privacy-title-lv2 {
    border-bottom: 1px solid;
    margin-block-end: 16px;
    font-size: 16px;
    font-weight: 700;
  }

  .privacy-unordered-list {
    padding: 0;
  }

  .privacy-unordered-list-item {
    display: grid;
    grid-template-columns: 4px 1fr;
    gap: .5em;
    padding-inline-start: .5em;

    &::before {
      content: "";
      width: 4px;
      height: 4px;
      border-radius: 50%;
      margin-block-start: 12px;
      background-color: currentColor;
    }
  }

  .privacy-ordered-list {
    padding-inline-start: .5em;
    list-style: decimal inside;
  }

  .privacy-link {
    text-decoration: underline;
    text-decoration-skip-ink: none;
  }

  .privacy-effective-date {
    margin-block-start: 32px;
  }

  .privacy-effective-date-list {
    display: flex;

    dt {
      font-weight: 400;

      &::after {
        content: "：";
      }
    }
  }

  @include mq() {
    .privacy-content {
      padding-block-end: 120px;
      margin-block-start: 100px;
    }

    .privacy-container {
      max-width: calc(800px + 80px * 2);
    }

    .privacy-section {
      margin-block-start: 40px;
    }

    .privacy-effective-date {
      margin-block-start: 40px;
    }
  }
</style>
