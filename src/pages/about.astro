---
import Layout from "../layouts/Layout.astro";
import PageKv from "../components/common/PageKv.astro";
import AboutThoughts from "../components/about/AboutThoughts.astro";
import AboutProfile from "../components/about/AboutProfile.astro";
import AboutFeatures from "../components/about/AboutFeatures.astro";
import AboutPurpose from "../components/about/AboutPurpose.astro";
import AboutMessage from "../components/about/AboutMessage.astro";
import Breadcrumb from "../components/common/Breadcrumb.astro";
import Cta from "../components/common/Cta.astro";

---

<Layout
  title="アロヒラニについて｜Ka Pā Hula O Alohilani"
  ogType="website"
  description="アロヒラニの想いや教室の特徴をご紹介します。フラを通して仲間とつながり、心豊かな時間を過ごせるコミュニティを目指しています。"
>
  <main class="about">
    <!-- about-kv -->
    <div class="about-kv">
      <PageKv
        pageTitle="アロヒラニについて"
        pageTitleEnglish="ABOUT ME"
        pageTitleImagePath="/assets/images/text/text-page-title-about.svg"
        pageTitleImageWidth="176"
        pageTitleImageHeight="46"
      />
    </div>

    <!-- about-thoughts -->
    <AboutThoughts />

    <!-- about-profile -->
    <AboutProfile />

    <!-- about-features -->
    <AboutFeatures />

    <!-- about-purpose -->
    <AboutPurpose />

    <!-- about-message -->
    <AboutMessage />

    <!-- breadcrumb -->
    <Breadcrumb
      siteUrl="https://alohilani-hula.com"
      breadcrumbLists={[{ name: "アロヒラニについて", schemaName: "アロヒラニについて" }]}
    />
  </main>

  <!-- cta -->
  <Cta />

</Layout>
