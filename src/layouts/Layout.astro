---
import "../styles/style.scss";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";

const logo = "/assets/images/global/logo.png";
const logoAlt = "鈴鹿Web制作";
const {
  title = "所沢市のホームページ制作｜設計で成果につなげるWeb制作｜鈴鹿Web制作",
  ogType = "website",
  ogTitle = title,
  description = "埼玉県所沢市を拠点に、成果につながるホームページを設計・制作。コンテンツ・導線・運用まで一貫して設計し、公開後の改善まで見据えたWeb制作をご提案します。",
  ogDescription = description,
  ogImage = "https://suzu-shika.com/ogp.png",
  noIndex = false,
  jsonLd = [],
} = Astro.props;

const jsonLdList = Array.isArray(jsonLd)
  ? jsonLd
  : jsonLd
    ? [jsonLd]
    : [];
---

<!DOCTYPE html>
<html lang="ja" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    { noIndex && <meta name="robots" content="noindex, nofollow" /> }

    <!-- favicon -->
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" href="/android-chrome-256x256.png">

    <!-- ogp -->
    <meta property="og:site_name" content="鈴鹿Web制作">
    <meta property="og:url" content={`https://suzu-shika.com${Astro.url.pathname}`} />
    <meta property="og:type" content={ogType}>
    <meta property="og:title" content={ogTitle}>
    <meta property="og:description" content={ogDescription}>
    <meta property="og:image" content={ogImage}>
    <meta property="og:locale" content="ja_JP">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:description" content={ogDescription}>
    <meta name="twitter:image:src" content={ogImage}>

    <!-- JSON-LD -->
    {jsonLdList.map((item) => (
      <script type="application/ld+json" set:html={item}></script>
    ))}
  </head>

  <body id="body">
    <Header
      logo={logo}
      logoAlt={logoAlt}
    />

    <slot />

    <Footer
      logo={logo}
      logoAlt={logoAlt}
    />
  </body>
</html>
